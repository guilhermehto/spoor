# Postgres connection string.
# NOTE: `pnpm dev` (scripts/dev.sh) auto-assigns the Postgres port and the Vite
# port per worktree and exports DATABASE_URL / BETTER_AUTH_URL / APP_URL for you,
# so you do NOT need to set them for local dev. The values below are only used
# outside that script (e.g. drizzle-kit studio against a single instance).
DATABASE_URL=postgres://spoor:spoor@localhost:5433/spoor

# Postgres password used by docker-compose.yml (production compose)
# Change this before deploying
POSTGRES_PASSWORD=change-me

# better-auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Public base URL of the app (used by better-auth for cookie domain / CSRF)
# For local dev this is the Vite dev server address
BETTER_AUTH_URL=http://localhost:5173

# Public base URL of the app (used in the tracking snippet src attribute)
# Set to your production domain when deploying, e.g. https://analytics.example.com
APP_URL=http://localhost:5173

# Secret used to derive the daily visitor-hash salt via HMAC-SHA-256.
# Rotating this value invalidates all historical visitor hashes (sessions will
# appear as new visitors).  Generate with: openssl rand -base64 32
SPOOR_HASH_SECRET=change-me-generate-with-openssl-rand-base64-32

# Port the app listens on (default: 3000)
PORT=3000
